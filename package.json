{
  "name": "api-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cf-typegen": "wrangler types",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "eslint .",
    "test": "npm run cf-typegen && vitest run",
    "test:watch": "npm run cf-typegen && vitest",
    "typecheck": "npm run cf-typegen && tsc --noEmit && tsc -p tests/tsconfig.json --noEmit"
  },
  "dependencies": {
    "hono": "4.12.12",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.14.1",
    "@eslint/js": "10.0.1",
    "eslint": "10.2.0",
    "globals": "17.4.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vitest": "4.1.3",
    "wrangler": "4.80.0"
  }
}
